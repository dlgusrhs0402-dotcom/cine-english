<title>CineEnglish — 중간발표</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Noto Sans KR', sans-serif; background: #fff; color: #111; }

  /* 슬라이드 */
  .slide {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
    padding: 60px 100px;
    border-bottom: 1px solid #eee;
  }

  /* 슬라이드 번호 */
  .slide-num {
    font-size: 12px; color: #aaa; letter-spacing: 0.2em;
    margin-bottom: 20px;
  }

  /* 공통 태그 */
  .tag {
    display: inline-block;
    font-size: 12px; font-weight: 700; color: #fff;
    background: #111; padding: 4px 12px; border-radius: 4px;
    margin-bottom: 20px; letter-spacing: 0.05em;
  }

  h1 { font-size: 56px; font-weight: 700; line-height: 1.15; margin-bottom: 16px; }
  h1 span { color: #e05a2b; }
  h2 { font-size: 40px; font-weight: 700; line-height: 1.2; margin-bottom: 12px; }
  .lead { font-size: 17px; color: #555; line-height: 1.8; max-width: 600px; margin-bottom: 40px; }

  /* 메타 */
  .meta { display: flex; gap: 48px; margin-top: 40px; }
  .meta-item .label { font-size: 11px; color: #aaa; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 4px; }
  .meta-item .value { font-size: 15px; font-weight: 700; }

  /* 구분선 */
  hr { border: none; border-top: 2px solid #111; width: 48px; margin-bottom: 32px; }

  /* 문제 카드 */
  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 32px; }
  .card {
    border: 1px solid #e5e5e5; border-radius: 10px; padding: 28px 24px;
    border-top: 3px solid #111;
  }
  .card-num { font-size: 32px; font-weight: 700; color: #e5e5e5; margin-bottom: 12px; }
  .card h3 { font-size: 15px; font-weight: 700; margin-bottom: 8px; }
  .card p { font-size: 13px; color: #666; line-height: 1.7; }

  /* 통계 */
  .stats { display: flex; gap: 56px; margin-top: 40px; padding-top: 32px; border-top: 1px solid #eee; }
  .stat-num { font-size: 44px; font-weight: 700; color: #e05a2b; line-height: 1; }
  .stat-desc { font-size: 12px; color: #888; margin-top: 6px; line-height: 1.5; }

  /* 비전 */
  .vision-quote {
    font-size: 28px; font-weight: 700; line-height: 1.5;
    max-width: 700px; margin-bottom: 40px;
    padding-left: 20px; border-left: 4px solid #e05a2b;
  }
  .vision-quote em { color: #e05a2b; font-style: normal; }

  .pillars { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 8px; }
  .pillar { padding: 20px; background: #f8f8f8; border-radius: 8px; }
  .pillar-icon { font-size: 24px; margin-bottom: 10px; }
  .pillar h4 { font-size: 14px; font-weight: 700; margin-bottom: 6px; }
  .pillar p { font-size: 12px; color: #777; line-height: 1.6; }

  /* 아키텍처 */
  .mermaid-wrap {
    margin-top: 28px; padding: 32px;
    background: #f8f8f8; border-radius: 10px;
    overflow: auto;
  }

  /* WBS 링크 슬라이드 */
  #s5 { align-items: flex-start; }
  .wbs-btn {
    display: inline-block; margin-top: 24px;
    padding: 14px 28px; background: #111; color: #fff;
    font-size: 15px; font-weight: 700; border-radius: 6px;
    text-decoration: none; transition: opacity 0.15s;
  }
  .wbs-btn:hover { opacity: 0.75; }

  /* 우측 내비 */
  .nav {
    position: fixed; right: 24px; top: 50%; transform: translateY(-50%);
    display: flex; flex-direction: column; gap: 10px; z-index: 100;
  }
  .nav button {
    width: 8px; height: 8px; border-radius: 50%;
    background: #ccc; border: none; cursor: pointer; transition: all 0.2s;
  }
  .nav button.on { background: #111; transform: scale(1.5); }
</style>
</head>
